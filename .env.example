# ===== Configuración del Planificador Boda M & A =====
# Copia este archivo como ".env" (o define estas variables en tu hosting).
# Si NO las defines, la app usa archivos JSON locales en la carpeta data/.

# Puerto del servidor (opcional)
PORT=3000

# Supabase (opcional — para guardar en la nube en producción)
SUPABASE_URL=
SUPABASE_KEY=
